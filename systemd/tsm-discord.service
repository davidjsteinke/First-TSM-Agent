[Unit]
Description=TSM Discord Reagent Alerts — posts top buys/sells to Discord
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=%h/tsm-agent
ExecStart=/usr/bin/python3 %h/tsm-agent/discord_alerts.py
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target
