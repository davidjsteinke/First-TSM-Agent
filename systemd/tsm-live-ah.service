[Unit]
Description=TSM Live Auction House Refresh — fetches AH snapshots, regenerates dashboard
After=network-online.target
Wants=network-online.target

[Service]
Type=oneshot
WorkingDirectory=%h/tsm-agent
ExecStart=/usr/bin/bash %h/tsm-agent/refresh_live_ah.sh
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=default.target
